# ---------------------------------------------------------------------------
# .env.example — copy to .env and fill in your real values
# DO NOT commit .env to version control
# ---------------------------------------------------------------------------

# ============================================================
# DATABASE
# ============================================================

# Async PostgreSQL connection string.
# Local (Docker): postgresql+asyncpg://postgres:postgres@db:5432/spark
# Render managed DB example:
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/spark_db

# ============================================================
# SECURITY — JWT
# ============================================================

# Long random string — generate with: openssl rand -hex 32
SECRET_KEY=replace_me_with_a_long_random_secret_key

# JWT signing algorithm (do not change unless you know what you're doing)
ALGORITHM=HS256

# Access token lifetime in minutes (default 30 = 30 min)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token lifetime in days (default 7 = 1 week)
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================
# CORS
# ============================================================

# Comma-separated list of allowed frontend origins.
# Wildcards (*) are NOT safe in production.
# Local dev: http://localhost:5173
# Production: your Vercel URL
CORS_ORIGINS=http://localhost:5173,https://your-project.vercel.app

# ============================================================
# DATABASE POOL (optional — defaults are fine for most use cases)
# ============================================================

# Max number of persistent connections in the pool
DB_POOL_SIZE=10

# Extra connections allowed beyond the pool limit (for bursts)
DB_MAX_OVERFLOW=20

# ============================================================
# PHI-4 MINI AI (Microsoft) — SPARK AI Co-Pilot
# ============================================================
# SPARK uses Microsoft Phi-4 Mini for AI narratives, student coaching,
# placement analysis, and the global Ctrl+K command bar.
#
# OPTION 1 — Ollama (local, free, offline-capable)
#   1. Install Ollama: https://ollama.ai
#   2. Run: ollama pull phi4-mini
#   3. Run: ollama serve
#   4. Set PHI4_API_URL=http://localhost:11434/v1
#   5. PHI4_API_KEY can be anything (e.g. "ollama")
#
# OPTION 2 — Azure AI Foundry (cloud, scalable)
#   Set PHI4_API_URL to your Azure AI endpoint
#   Set PHI4_API_KEY to your Azure API key
#
# OPTION 3 — OpenRouter / Together.ai (hosted)
#   PHI4_API_URL=https://openrouter.ai/api/v1
#   PHI4_API_KEY=your_openrouter_api_key
#   PHI4_MODEL=microsoft/phi-4-mini   (check provider's model ID)
#
# If PHI4_API_URL is not set, the service defaults to Ollama localhost.
# All AI endpoints are gracefully degraded — the dashboard works without AI.

PHI4_API_URL=http://localhost:11434/v1
PHI4_API_KEY=ollama
PHI4_MODEL=phi4-mini
PHI4_STREAM_ENABLED=true

# ============================================================
# AI (DeepSeek via NVIDIA Integrate)
# ============================================================
# OpenAI-compatible endpoint hosted by NVIDIA (or any other
# compatible provider). Keep your real key in your private .env.
AI_API_URL=https://integrate.api.nvidia.com/v1
AI_API_KEY=nvapi-your-api-key-here
AI_MODEL=stepfun-ai/step-3.5-flash
AI_STREAM_ENABLED=true
